// Linear Search

a1 = arr[1, 10, 5, 6, 4, 7, 19]
key = 4

fun Linear_Search(@init<table> a, k):
    for @mark<outline, yellow> (n in a):
        @mark<n, text, fg> if (n == k):
            @mark<highlight, green> return n
        end if
    end for

    @log<"Not found: "> return -1
end fun

result = Linear_Search(a1, key)
